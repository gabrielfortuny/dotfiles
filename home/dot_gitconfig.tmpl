[user]
  name = "{{ .git.name }}"
  email = "{{ .git.email }}"
  signingkey = "{{ .git.signingkey }}"

[commit]
  gpgsign = true

[gpg]
  format = ssh

[gpg "ssh"]
  program = "{{ .git.ssh_program }}"
  allowedSignersFile = ~/.ssh/allowed_signers

[init]
  defaultBranch = main

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true

[format]
    pretty = "%C(yellow)%h%Creset%C(auto)%d%Creset %s %C(dim green)(%ar)%Creset %C(dim blue)<%an>%Creset"

[log]
    decorate = auto
